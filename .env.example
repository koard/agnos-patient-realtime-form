# ─── Ably Real-time Provider ──────────────────────────────────────────────────
# Get your API key from https://ably.com → App dashboard → API Keys
# Use the key with "Publish" and "Subscribe" capabilities.
# The NEXT_PUBLIC_ prefix exposes this to the browser bundle (required for client-side Ably).
# WARNING: In production, prefer Ably Token Authentication (see README) to avoid
# exposing the full API key in the client bundle.
NEXT_PUBLIC_ABLY_API_KEY=your_ably_api_key_here
